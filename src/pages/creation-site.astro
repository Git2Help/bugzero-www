---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
---

<Layout>
  <fragment slot="header">
    <Header />
  </fragment>

  <Section>
    <div class="text-center mb-10">
      <span class="text-sm font-normal" style="color:#696969;">Création de site</span>
      <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
        Un site internet qui vous rapporte des clients. Créé sur mesure.
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm" style="color:#696969;">
        Jusqu'à 70% de subvention grâce au Fonds Bleu Monaco. 2 mois de maintenance offerts.
      </p>
    </div>
    <div class="text-center">
      <a href="/contact/" class="inline-flex items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-medium text-white transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5" style="background-color:#009EE0;">
        Je veux mon site
      </a>
    </div>
  </Section>

  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
      <div>
        <h3 class="text-2xl font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Ce que nous créons pour vous</h3>
        <ul class="mt-4 space-y-2 text-sm" style="color:#696969;">
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgb(217, 224, 33);"><path d="M20 6 9 17l-5-5"></path></svg>
            Sites vitrines, e-commerce, réservation en ligne
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgb(217, 224, 33);"><path d="M20 6 9 17l-5-5"></path></svg>
            Design responsive, optimisé mobile
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgb(217, 224, 33);"><path d="M20 6 9 17l-5-5"></path></svg>
            Référencement SEO intégré (mots-clés, contenu, balisage)
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgb(217, 224, 33);"><path d="M20 6 9 17l-5-5"></path></svg>
            Formulaires de contact, liens réseaux sociaux, blog
          </li>
        </ul>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85" style="border-color: rgba(0, 158, 224, 0.3);">
        <h4 class="text-sm font-semibold mb-3" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Votre projet en 3 étapes</h4>
        <ol class="space-y-3 text-sm" style="color:#696969;">
          <li><strong>1.</strong> Brief découverte (gratuit, 30 min)</li>
          <li><strong>2.</strong> Maquette et validation sous 7 jours</li>
          <li><strong>3.</strong> Mise en ligne et formation à la mise à jour</li>
        </ol>
      </div>
    </div>
  </Section>

  <Section>
    <div class="text-center">
      <h3 class="text-2xl font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Fonds Bleu</h3>
      <p class="mt-4 text-sm max-w-xl mx-auto" style="color:#696969;">
        Vous êtes une entreprise monégasque ? L'État prend en charge 30 à 70% du coût. Nous montons le dossier avec vous.
      </p>
      <p class="mt-6 italic text-sm" style="color:#696969;">
        « Bugzero a créé notre boutique en ligne en 3 semaines. Nos ventes ont triplé. »
      </p>
      <p class="mt-1 text-sm font-semibold" style="color: rgb(0, 158, 224);">Commerçant à Monaco</p>
      <div class="mt-8">
        <a href="/contact/" class="inline-flex items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-medium text-white transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5" style="background-color:#009EE0;">
          Démarrer mon projet
        </a>
      </div>
    </div>
  </Section>

  <fragment slot="footer">
    <Footer />
  </fragment>
</Layout>