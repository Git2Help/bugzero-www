---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
---

<Layout>
  <fragment slot="header">
    <Header />
  </fragment>

  <Section>
    <div class="text-center mb-10">
      <span class="text-sm font-normal" style="color:#696969;">Maintenance Pro</span>
      <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
        Votre service IT dedie, sans le salaire. Des 59 € HT/mois.
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm" style="color:#696969;">
        Surveillance 24/7, antivirus, sauvegardes et support inclus.
      </p>
    </div>
    <div class="text-center">
      <a href="#formules" class="inline-flex items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-medium text-white transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5" style="background-color:#009EE0;">
        Comparer les formules
      </a>
    </div>
  </Section>

  <Section id="formules">
    <div class="text-center mb-10">
      <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
        Tableau comparatif
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="rounded-2xl border p-6 bg-white/85" style="border-color: rgba(0, 158, 224, 0.3);">
        <p class="text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Supervision-Assistance</p>
        <p class="mt-2 text-3xl font-semibold" style="color: rgb(0, 158, 224);">59 € HT</p>
        <p class="text-xs" style="color:#696969;">/mois</p>
        <p class="mt-2 text-xs" style="color:#696969;">Supervision automatique, antivirus Bitdefender, sauvegarde MSP360. L'essentiel pour demarrer.</p>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85" style="border-color: rgba(0, 158, 224, 0.3);">
        <p class="text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Liberte</p>
        <p class="mt-2 text-3xl font-semibold" style="color: rgb(0, 158, 224);">79 € HT</p>
        <p class="text-xs" style="color:#696969;">/mois</p>
        <p class="mt-2 text-xs" style="color:#696969;">+1 appel/mois, 6 tickets, assistance a distance. Un pas vers la tranquillite.</p>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85" style="border-color: rgba(0, 158, 224, 0.3);">
        <p class="text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Puissance</p>
        <p class="mt-2 text-3xl font-semibold" style="color: rgb(0, 158, 224);">149 € HT</p>
        <p class="text-xs" style="color:#696969;">/mois</p>
        <p class="mt-2 text-xs" style="color:#696969;">+3 appels, 3h sur site Monaco/PACA. Pour les equipes actives.</p>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85" style="border-color: rgba(0, 158, 224, 0.3);">
        <p class="text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Illimitee</p>
        <p class="mt-2 text-3xl font-semibold" style="color: rgb(0, 158, 224);">249 € HT</p>
        <p class="text-xs" style="color:#696969;">/mois</p>
        <p class="mt-2 text-xs" style="color:#696969;">Appels illimites, 1 journee de presence sur site/mois. La totale serenite.</p>
      </div>
    </div>
  </Section>

  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
      <div>
        <h3 class="text-2xl font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Pourquoi choisir Bugzero</h3>
        <ul class="mt-4 space-y-2 text-sm" style="color:#696969;">
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgb(217, 224, 33);"><path d="M20 6 9 17l-5-5"></path></svg>
            Reponse en moins de 2h en heures ouvrees
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgb(217, 224, 33);"><path d="M20 6 9 17l-5-5"></path></svg>
            Antivirus nouvelle generation anti-ransomware
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgb(217, 224, 33);"><path d="M20 6 9 17l-5-5"></path></svg>
            Sauvegardes cloud automatiques, restaurables en un clic
          </li>
        </ul>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85" style="border-color: rgba(0, 158, 224, 0.3);">
        <p class="italic text-sm" style="color:#696969;">
          &laquo; Depuis que Bugzero gere notre maintenance, on n'a plus jamais perdu un fichier. &raquo;
        </p>
        <p class="mt-2 text-sm font-semibold" style="color: rgb(0, 158, 224);">Cabinet comptable, Nice</p>
      </div>
    </div>
    <div class="text-center mt-10">
      <a href="/contact" class="inline-flex items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-medium text-white transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5" style="background-color:#009EE0;">
        Je choisis ma formule
      </a>
    </div>
  </Section>

  <fragment slot="footer">
    <Footer />
  </fragment>
</Layout>