---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
---

<Layout>
  <fragment slot="header">
    <Header />
  </fragment>

  <Section>
    <div class="text-center mb-10">
      <span class="text-sm font-normal" style="color:#696969;">Contact</span>
      <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
        Contactez-nous
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm" style="color:#696969;">
        Une question ? Un problème ? Notre équipe est là pour vous répondre.
      </p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div>
        <div class="mt-6 space-y-4">
          <div class="flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </span>
            <div>
              <p class="text-sm font-medium" style="color: rgb(0, 158, 224);">06 78 56 54 30</p>
              <p class="text-xs" style="color:#696969;">Du lundi au vendredi, 9h-18h</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="mail"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            </span>
            <div>
              <p class="text-sm font-medium" style="color: rgb(0, 158, 224);">bonjour@bugzero.fr</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </span>
            <div>
              <p class="text-sm font-medium" style="color: rgb(0, 158, 224);">9, Allée Lazare Sauvaigo</p>
              <p class="text-xs" style="color:#696969;">98000 Monaco</p>
            </div>
          </div>
        </div>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85" style="border-color: rgba(0, 158, 224, 0.3);">
        <p class="text-sm font-semibold mb-4" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Envoyez-nous un message</p>
        <form class="space-y-4">
          <div>
            <input type="text" placeholder="Nom" class="w-full rounded-xl border px-4 py-2.5 text-sm bg-white" style="border-color: rgba(0, 158, 224, 0.3); color:#696969;">
          </div>
          <div>
            <input type="email" placeholder="Email" class="w-full rounded-xl border px-4 py-2.5 text-sm bg-white" style="border-color: rgba(0, 158, 224, 0.3); color:#696969;">
          </div>
          <div>
            <textarea placeholder="Votre message" rows="4" class="w-full rounded-xl border px-4 py-2.5 text-sm bg-white" style="border-color: rgba(0, 158, 224, 0.3); color:#696969;"></textarea>
          </div>
          <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3 text-sm font-medium text-white transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 w-full" style="background-color: rgb(0, 158, 224);">
            Envoyer
          </button>
        </form>
      </div>
    </div>
  </Section>

  <fragment slot="footer">
    <Footer />
  </fragment>
</Layout>