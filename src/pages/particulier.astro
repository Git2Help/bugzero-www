---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
---

<Layout>
  <fragment slot="header">
    <Header />
  </fragment>

  <!-- Section 1: Hero -->
  <section class="relative overflow-hidden group animate-fade-in bg-neutral-50 border-neutral-200 border rounded-3xl shadow-[0_2.8px_2.2px_rgba(0,_0,_0,_0.034),_0_6.7px_5.3px_rgba(0,_0,_0,_0.048),_0_12.5px_10px_rgba(0,_0,_0,_0.06),_0_22.3px_17.9px_rgba(0,_0,_0,_0.072),_0_41.8px_33.4px_rgba(0,_0,_0,_0.086),_0_100px_80px_rgba(0,_0,_0,_0.12)]" style="animation: 0.8s ease-out fadeIn; border-color: rgba(0, 158, 224, 0.3); background-color: rgba(255, 255, 255, 0.85);">
    <div class="relative grid grid-cols-1 gap-8 sm:p-10 lg:grid-cols-12 lg:gap-10 pt-6 pr-6 pb-6 pl-6">
      <div class="flex flex-col justify-center lg:col-span-7">
        <div class="max-w-xl">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border bg-white/70 px-3 py-1 text-xs font-medium backdrop-blur transition-all duration-300" style="border-color: rgba(0, 158, 224, 0.3); color: rgb(105, 105, 105);">
            <span class="flex h-5 w-5 items-center justify-center rounded-full text-white" style="background-color: rgb(0, 158, 224);">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" data-lucide="laptop">
                <path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"></path>
              </svg>
            </span>
            <span style="color: rgb(0, 158, 224);">D&eacute;pannage informatique</span>
            <span class="mx-1.5 h-1 w-1 rounded-full" style="background-color: rgb(217, 224, 33);"></span>
            <span>Monaco &amp; C&ocirc;te d'Azur</span>
          </div>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
            Votre PC ne marche plus&nbsp;?
            <br>
            On s'en occupe.
          </h1>
          <p class="mt-5 max-w-lg text-lg leading-relaxed" style="color:#696969;">
            D&eacute;pannage rapide, maintenance pr&eacute;ventive et formation. Nos techniciens interviennent &agrave; Monaco, Nice et Menton.
          </p>
          <div class="flex flex-wrap gap-3 mt-8 items-center">
            <a href="#contact" class="flex gap-2 focus:outline-none focus:ring-2 transition-all duration-300 hover:shadow-xl hover:scale-105 text-sm font-medium text-white w-full max-w-xs rounded-xl pt-3.5 pr-6 pb-3.5 pl-6 shadow-lg items-center justify-center hover:-translate-y-1 active:scale-95" style="background-color: rgb(0, 158, 224); --tw-ring-color: rgba(0,158,224,0.35);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" data-lucide="calendar-clock">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14"></path>
                <path d="M16 22a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z"></path>
                <path d="M16 18.5v-3l1.5 1.5"></path>
                <path d="M7 4v4"></path>
                <path d="M17 4v4"></path>
                <path d="M3 10h18"></path>
              </svg>
              <span class="text-sm">Prendre rendez-vous</span>
            </a>
            <a href="#depannage" class="inline-flex gap-2 hover:bg-neutral-50 text-sm font-medium text-neutral-900 bg-white border-neutral-300 border rounded-xl pt-3 pr-4 pb-3 pl-4 items-center transition-all duration-300 hover:scale-105 hover:shadow-md hover:-translate-y-0.5 active:scale-95">
              En savoir plus
            </a>
          </div>
        </div>
      </div>
      <div class="lg:col-span-5 flex items-center justify-center">
        <div class="relative mx-auto aspect-square w-full max-w-sm overflow-hidden rounded-full border border-white/60 bg-white/80 shadow-lg backdrop-blur hover:scale-105 hover:shadow-2xl transition-all duration-500 hover:border-blue-300/60 group">
          <img src="https://images.unsplash.com/photo-1597851263798-1f56f896c76e?auto=format&amp;fit=crop&amp;w=800&amp;q=80" alt="D&eacute;pannage informatique" class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-500">
          <div class="pointer-events-none absolute inset-0 rounded-full ring-1 ring-inset ring-white/60"></div>
        </div>
      </div>
    </div>
    <style>
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
    </style>
  </section>

  <!-- Section 2: Dépannage à distance -->
  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
      <div>
        <span class="text-sm font-normal" style="color:#696969;">D&eacute;pannage &agrave; distance</span>
        <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
          Rapide, s&eacute;curis&eacute;, efficace
        </h2>
        <p class="mt-4 text-sm" style="color:#696969;">
          Notre technicien se connecte &agrave; distance &agrave; votre PC via une connexion s&eacute;curis&eacute;e. En moyenne, votre probl&egrave;me est r&eacute;solu en 30 minutes. Id&eacute;al pour les urgences et les bugs logiciels.
        </p>
        <div class="mt-6 flex items-center gap-4">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="clock"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </span>
          <span class="text-sm font-medium" style="color: rgb(0, 158, 224);">~30 minutes en moyenne</span>
        </div>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85" style="border-color: rgba(0, 158, 224, 0.3);">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="shield"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1 1 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"></path></svg>
          </span>
          <p class="text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Connexion s&eacute;curis&eacute;e</p>
        </div>
        <p class="text-sm" style="color:#696969;">
          Acc&egrave;s chiffr&eacute; de bout en bout. Vous contr&ocirc;lez la session &agrave; tout moment. Aucune donn&eacute;e n'est conserv&eacute;e apr&egrave;s l'intervention.
        </p>
      </div>
    </div>
  </Section>

  <!-- Section 3: Dépannage sur site -->
  <Section>
    <div class="text-center mb-10">
      <span class="text-sm font-normal" style="color:#696969;">D&eacute;pannage sur site</span>
      <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
        Nous venons chez vous
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm" style="color:#696969;">
        Nos techniciens se d&eacute;placent &agrave; Monaco, Nice, Menton et dans les Alpes-Maritimes.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="rounded-2xl border p-6 bg-white/85 text-center hover:shadow-lg transition-all duration-300" style="border-color: rgba(0, 158, 224, 0.3);">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" data-lucide="building"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path><path d="M12 10h.01"></path><path d="M12 14h.01"></path><path d="M16 10h.01"></path><path d="M16 14h.01"></path><path d="M8 10h.01"></path><path d="M8 14h.01"></path></svg>
        </span>
        <p class="mt-4 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Monaco</p>
        <p class="mt-2 text-sm" style="color:#696969;">
          Intervention sous 24h ouvr&eacute;es dans toute la Principaut&eacute;.
        </p>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85 text-center hover:shadow-lg transition-all duration-300" style="border-color: rgba(0, 158, 224, 0.3);">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" data-lucide="landmark"><path d="M3 22h18"></path><path d="M6 18v-8"></path><path d="M10 18v-8"></path><path d="M14 18v-8"></path><path d="M18 18v-8"></path><path d="M12 2 2 7l10 5 10-5-10-5Z"></path></svg>
        </span>
        <p class="mt-4 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Nice</p>
        <p class="mt-2 text-sm" style="color:#696969;">
          D&eacute;placement rapide dans Nice et sa m&eacute;tropole.
        </p>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85 text-center hover:shadow-lg transition-all duration-300" style="border-color: rgba(0, 158, 224, 0.3);">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" data-lucide="mountain"><path d="m8 3 4 8 5-5 5 15H2L8 3z"></path></svg>
        </span>
        <p class="mt-4 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Menton</p>
        <p class="mt-2 text-sm" style="color:#696969;">
          Interventions &agrave; Menton et dans l'arri&egrave;re-pays.
        </p>
      </div>
    </div>
  </Section>

  <!-- Section 4: Maintenance préventive -->
  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
      <div>
        <span class="text-sm font-normal" style="color:#696969;">Maintenance pr&eacute;ventive</span>
        <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
          Anticipez les pannes
        </h2>
        <p class="mt-4 text-sm" style="color:#696969;">
          Nettoyage, optimisation, antivirus et sauvegarde. Un entretien r&eacute;gulier prolonge la dur&eacute;e de vie de votre mat&eacute;riel et &eacute;vite les mauvaises surprises.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-2xl border p-5 bg-white/80" style="border-color: rgba(0, 158, 224, 0.3);">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" data-lucide="spray-can"><path d="M3 3h3v18H3Z"></path><path d="M6 4h8l4 4v14H6Z"></path><path d="M10 12h4"></path></svg>
          </span>
          <p class="mt-3 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Nettoyage</p>
          <p class="mt-1 text-sm" style="color:#696969;">Physique et logiciel de votre PC.</p>
        </div>
        <div class="rounded-2xl border p-5 bg-white/80" style="border-color: rgba(0, 158, 224, 0.3);">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" data-lucide="shield"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1 1 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"></path></svg>
          </span>
          <p class="mt-3 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Antivirus</p>
          <p class="mt-1 text-sm" style="color:#696969;">Protection contre les malwares.</p>
        </div>
        <div class="rounded-2xl border p-5 bg-white/80" style="border-color: rgba(0, 158, 224, 0.3);">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" data-lucide="hard-drive"><path d="M22 12 2 12"></path><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"></path></svg>
          </span>
          <p class="mt-3 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Sauvegarde</p>
          <p class="mt-1 text-sm" style="color:#696969;">Vos donn&eacute;es en s&eacute;curit&eacute;.</p>
        </div>
        <div class="rounded-2xl border p-5 bg-white/80" style="border-color: rgba(0, 158, 224, 0.3);">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" data-lucide="zap"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg>
          </span>
          <p class="mt-3 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Optimisation</p>
          <p class="mt-1 text-sm" style="color:#696969;">PC plus rapide au quotidien.</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Section 5: Formation -->
  <Section>
    <div class="text-center mb-10">
      <span class="text-sm font-normal" style="color:#696969;">Formation</span>
      <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
        Apprenez &agrave; votre rythme
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm" style="color:#696969;">
        Formations individuelles ou en petit groupe sur les logiciels courants.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="rounded-2xl border p-6 bg-white/85 hover:shadow-lg transition-all duration-300" style="border-color: rgba(0, 158, 224, 0.3);">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" data-lucide="file-text"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg>
        </span>
        <p class="mt-4 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Traitement de texte</p>
        <p class="mt-2 text-sm" style="color:#696969;">
          Word, LibreOffice &eacute;criture, mise en page, publipostage.
        </p>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85 hover:shadow-lg transition-all duration-300" style="border-color: rgba(0, 158, 224, 0.3);">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" data-lucide="calculator"><rect x="4" y="2" width="16" height="20" rx="2"></rect><path d="M8 6h8"></path><path d="M8 12h8"></path><path d="M8 18h8"></path><path d="M8 18h8"></path></svg>
        </span>
        <p class="mt-4 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Comptabilit&eacute;</p>
        <p class="mt-2 text-sm" style="color:#696969;">
          Excel, tableurs, gestion budg&eacute;taire et facturation.
        </p>
      </div>
      <div class="rounded-2xl border p-6 bg-white/85 hover:shadow-lg transition-all duration-300" style="border-color: rgba(0, 158, 224, 0.3);">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" data-lucide="monitor"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><path d="M8 21h8"></path><path d="M12 17v4"></path></svg>
        </span>
        <p class="mt-4 text-sm font-semibold" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">Logiciels m&eacute;tier</p>
        <p class="mt-2 text-sm" style="color:#696969;">
          Prise en main de vos logiciels professionnels.
        </p>
      </div>
    </div>
  </Section>

  <!-- Section 6: Contact -->
  <Section id="contact">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div>
        <span class="text-sm font-normal" style="color:#696969;">Contact</span>
        <h2 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight" style="font-family: &quot;Futura Sd&quot;, Futura, &quot;Trebuchet MS&quot;, sans-serif; color: rgb(0, 158, 224);">
          Besoin d'aide&nbsp;?
        </h2>
        <p class="mt-4 text-sm" style="color:#696969;">
          Contactez-nous pour un devis gratuit ou prendre rendez-vous.
        </p>
        <div class="mt-6 space-y-4">
          <div class="flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl" style="background-color: rgba(217, 224, 33, 0.3); color: rgb(0, 158, 224);">
