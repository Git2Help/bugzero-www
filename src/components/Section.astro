---
export interface Props {
  id?: string;
  bg?: string;
}

const { id, bg = "bg-white/80" } = Astro.props;
---

<section class={`sm:p-8 max-w-7xl border rounded-3xl mt-20 pt-6 pr-6 pb-6 pl-6 shadow-[0_2.8px_2.2px_rgba(0,_0,_0,_0.034),_0_6.7px_5.3px_rgba(0,_0,_0,_0.048),_0_12.5px_10px_rgba(0,_0,_0,_0.06),_0_22.3px_17.9px_rgba(0,_0,_0,_0.072),_0_41.8px_33.4px_rgba(0,_0,_0,_0.086),_0_100px_80px_rgba(0,_0,_0,_0.12)] ${bg}`} id={id} style="border-color: rgba(0, 158, 224, 0.3);">
  <slot />
</section>